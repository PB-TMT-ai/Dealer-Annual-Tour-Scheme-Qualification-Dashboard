SUPABASE_URL=your_url
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
STREAMLIT_SERVER_PORT=8501
APP_ENV=development

# SharePoint Excel Integration
# Paste the direct download link for your SharePoint/OneDrive Excel file.
# To get this: open the file in SharePoint → Share → "Anyone with the link" → Copy link
# Then replace the URL below. Leave empty to use local files only.
SHAREPOINT_EXCEL_URL=
